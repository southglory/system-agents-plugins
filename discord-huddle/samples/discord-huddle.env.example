# Copy this file to .claude/secrets/discord-huddle.env and fill in the values.
# Never commit the actual .env — it contains a secret bot token.

# ─── Required ────────────────────────────────────────────────────────────
# Discord Bot Token. Generate in Discord Developer Portal → Bot → Reset Token.
DISCORD_BOT_TOKEN=

# Target channel ID. Enable Developer Mode in Discord, right-click the channel,
# and choose "Copy Channel ID".
DISCORD_CHANNEL_ID=

# ─── Optional: path overrides ────────────────────────────────────────────
# All are resolved relative to project root unless absolute.

# Override project root detection (else uses CWD walk for a `.claude/` dir).
# SYSTEM_AGENTS_PROJECT_ROOT=/absolute/path/to/project

# Runtime data (raw JSONL, inbox signals, local-state.json, vc snapshots).
# Default: .system-agents/discord-huddle
# DISCORD_HUDDLE_DATA_DIR=.system-agents/discord-huddle

# Team-shared summaries (meeting notes + index.json).
# Default: docs/discord-huddle-summaries
# DISCORD_HUDDLE_SUMMARY_DIR=docs/discord-huddle-summaries

# Override this .env file's own path (rarely needed).
# DISCORD_HUDDLE_ENV=.claude/secrets/discord-huddle.env
