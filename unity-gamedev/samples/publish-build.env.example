# Optional env vars for unity-gamedev. Copy to .claude/secrets/publish-build.env
# only if you want to set defaults for every /publish-build invocation.
# All of these can also be passed on the CLI as flags.

# Pin the Unity project root (useful if you run the command from elsewhere).
# If unset, the plugin walks up from CWD looking for Assets/+ProjectSettings/.
# SYSTEM_AGENTS_PROJECT_ROOT=/absolute/path/to/UnityProject

# There's nothing secret here by default — this file exists only so you
# have a documented place to put convenience defaults. No token is required:
# the plugin authenticates via your existing `gh` login.
